# AWS Unified MCP Server Configuration

# Server Configuration
MCP_HTTP_PORT=3000
PORT=3000
NODE_ENV=production

# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET=edge-backup-picluster-free

# Authentication & Security
JWT_SECRET=your-secret-jwt-key-here
PIPEDREAM_API_KEY=your-pipedream-api-key
MONITORING_API_KEY=your-monitoring-api-key
ADMIN_API_KEY=your-admin-api-key

# Rate Limiting
RATE_LIMIT_MAX=100

# Oracle Database Configuration
ORACLE_HOST=your-oracle-host
ORACLE_PORT=1521
ORACLE_USER=your-oracle-user
ORACLE_PASSWORD=your-oracle-password
ORACLE_SERVICE_NAME=your-service-name

# SSH Process Pool Configuration
# Maximum number of concurrent SSH connections (default: 3)
MCP_SSH_POOL_SIZE=3

# SSH connection timeout in milliseconds (default: 8000)
MCP_SSH_TIMEOUT=8000

# Logging
LOG_DIR=/tmp/mcp-logs

# DigitalOcean Configuration (optional)
DIGITALOCEAN_API_KEY=your-digitalocean-api-key

# 1Password Configuration (optional)
ONEPASSWORD_VAULT=Personal