# Cloud-Ops Platform Environment Configuration
# Copy this file to .env and fill in your values

# Environment Settings
CLOUD_OPS_ENV=development  # development, staging, production

# API Configuration
API_HOST=0.0.0.0
API_PORT=5001

# Oracle Database Configuration
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=FREE
ORACLE_USER=ANALYTICS
ORACLE_PASSWORD=your_oracle_password_here

# AWS Unified MCP Server
AWS_UNIFIED_URL=http://localhost:3000
AWS_UNIFIED_TIMEOUT=30

# Notion Configuration
NOTION_TOKEN=your_notion_integration_token_here
NOTION_RESOURCES_DB_ID=your_resources_database_id_here
NOTION_PROJECTS_DB_ID=your_projects_database_id_here
NOTION_INCIDENTS_DB_ID=your_incidents_database_id_here
NOTION_TASKS_DB_ID=your_tasks_database_id_here

# Pipedream Webhook URLs
# Get these from your Pipedream workflow HTTP triggers
PIPEDREAM_BUDGET_ALERT_URL=https://your-budget-alert-webhook.m.pipedream.net
PIPEDREAM_ANOMALY_DETECTION_URL=https://your-anomaly-detection-webhook.m.pipedream.net
PIPEDREAM_COST_OPTIMIZATION_URL=https://your-cost-optimization-webhook.m.pipedream.net
PIPEDREAM_SYNC_COMPLETION_URL=https://your-sync-completion-webhook.m.pipedream.net

# Project Configuration
DEFAULT_PROJECT_ID=cloud-ops-prod
MONTHLY_BUDGET=10.0

# Alert Thresholds
BUDGET_WARNING_THRESHOLD=0.75      # 75%
BUDGET_CRITICAL_THRESHOLD=0.90     # 90%
CPU_UNDERUTILIZED_THRESHOLD=20     # 20%
MEMORY_UNDERUTILIZED_THRESHOLD=30  # 30%
ANOMALY_WARNING_THRESHOLD=0.6      # 0.6 score
ANOMALY_CRITICAL_THRESHOLD=0.8     # 0.8 score

# Notification Settings (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=alerts@your-domain.com
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key_here

# Sync Service Settings
SYNC_INTERVAL_HOURS=1              # Hourly metrics sync
FULL_SYNC_HOUR=2                   # 2 AM daily full sync
OPTIMIZATION_DAY=sunday            # Weekly optimization

# Grafana Settings (for Docker deployment)
GRAFANA_ORACLE_PROXY_URL=http://oracle-proxy:5002