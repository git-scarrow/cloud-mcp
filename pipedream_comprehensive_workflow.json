      "id": "notion_operations",
      "name": "Update Notion Databases",
      "type": "code",
      "code": `
export default defineComponent({
  props: {
    notion: {
      type: "app",
      app: "notion"
    }
  },
  async run({ steps, $ }) {
    const { inputType } = steps.input_router.$return_value;
    const oracleData = steps.oracle_metrics.$return_value;
    
    const operations = [];
    
    // Create incident page if needed
    if (inputType === 'webhook' || inputType === 'email') {
      operations.push({
        type: 'create_incident',
        database_id: '23be7cc7-01d5-813f-8bc4-e73325f0535a',
        properties: {
          Name: {
            title: [{
              text: { 
                content: \`🚨 \${oracleData.ai_insights.severity}: \${oracleData.current_incident.original.alert_type || 'Incident'}\`
              }
            }]
          },
          Status: {
            select: { name: "Active" }
          },
          "Budget Status": {
            formula: oracleData.ai_insights.cost_impact || "Unknown"
          }
        }
      });
    }
    
    // Update resource inventory
    if (oracleData.current_incident.original.resource_id) {
      operations.push({
        type: 'update_resource',
        database_id: '23be7cc7-01d5-81f0-a8cc-cfa88a213102',
        filter: {
          property: 'Resource UUID',
          equals: oracleData.current_incident.original.resource_id
        },
        updates: {
          Status: {
            select: { 
              name: oracleData.ai_insights.severity === 'Critical' ? '🔴 Critical' : '🟡 Warning'
            }
          },
          "Optimization Flag": {
            select: {
              name: oracleData.historical_context.resource_optimization_opportunities.length > 0 
                ? "Right-size Candidate" 
                : "Normal"
            }
          },
          "Last Updated": {
            date: { start: new Date().toISOString() }
          }
        }
      });
    }
    
    // Execute all operations
    const results = [];
    for (const op of operations) {
      try {
        let result;
        if (op.type === 'create_incident') {
          result = await $.notion.pages.create({
            parent: { database_id: op.database_id },
            properties: op.properties
          });
        } else if (op.type === 'update_resource') {
          // Find and update the resource
          const pages = await $.notion.databases.query({
            database_id: op.database_id,
            filter: op.filter
          });
          
          if (pages.results.length > 0) {
            result = await $.notion.pages.update({
              page_id: pages.results[0].id,
              properties: op.updates
            });
          }
        }
        results.push({ operation: op.type, success: true, result });
      } catch (error) {
        results.push({ operation: op.type, success: false, error: error.message });
      }
    }
    
    return {
      operations_attempted: operations.length,
      results,
      notion_updated: results.some(r => r.success)
    };
  }
})`
    },
    
    {
      "id": "automated_remediation",
      "name": "Execute Automated Remediation",
      "type": "code", 
      "code": `
export default defineComponent({
  async run({ steps, $ }) {
    const analysis = steps.ai_analysis.$return_value;
    const enrichedData = steps.enrich_context.$return_value;
    
    const remediationActions = [];
    
    // Determine automated actions based on severity and type
    if (analysis.severity === 'Critical') {
      // Critical actions
      if (enrichedData.original.alert_type === 'high_cpu') {
        remediationActions.push({
          action: 'restart_service',
          target: enrichedData.original.resource_id,
          reason: 'CPU exceeded 90% for extended period'
        });
      }
      
      if (enrichedData.original.alert_type === 'disk_full') {
        remediationActions.push({
          action: 'cleanup_logs',
          target: enrichedData.original.resource_id,
          reason: 'Disk usage exceeded 95%'
        });
      }
    }
    
    // Execute remediation via MCP
    const results = [];
    for (const action of remediationActions) {
      try {
        const response = await fetch('http://localhost:3002/query', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service: 'edge',
            query: \`execute \${action.action} on \${action.target}\`,
            options: { 
              reason: action.reason,
              automated: true
            }
          })
        });
        
        results.push({
          action: action.action,
          success: response.ok,
          response: await response.text()
        });
      } catch (error) {
        results.push({
          action: action.action,
          success: false,
          error: error.message
        });
      }
    }
    
    return {
      automated_actions_taken: remediationActions.length,
      results,
      require_manual_intervention: analysis.severity === 'Critical' && results.some(r => !r.success)
    };
  }
})`
    },
    
    {
      "id": "multi_channel_notifications",
      "name": "Send Multi-Channel Notifications",
      "type": "code",
      "code": `
export default defineComponent({
  props: {
    slack: { type: "app", app: "slack" },
    discord: { type: "app", app: "discord" },
    email: { type: "app", app: "email" }
  },
  async run({ steps, $ }) {
    const analysis = steps.ai_analysis.$return_value;
    const notionOps = steps.notion_operations.$return_value;
    const remediation = steps.automated_remediation.$return_value;
    
    const severity = analysis.severity || 'Unknown';
    const emoji = {
      'Critical': '🚨',
      'High': '⚠️',
      'Medium': '📊',
      'Low': 'ℹ️'
    }[severity] || '❓';
    
    const message = \`\${emoji} **Cloud Operations Alert**
    
**Severity**: \${severity}
**Type**: \${steps.input_router.$return_value.data.alert_type || 'General'}
**Resource**: \${steps.input_router.$return_value.data.resource_id || 'N/A'}

**AI Analysis**:
• Root Cause: \${analysis.root_cause || 'Under investigation'}
• Cost Impact: \${analysis.cost_impact || 'Calculating...'}

**Automated Actions**: \${remediation.automated_actions_taken} taken
**Manual Required**: \${remediation.require_manual_intervention ? 'Yes' : 'No'}

**Notion Updated**: \${notionOps.notion_updated ? 'Yes' : 'Failed'}

View full details in Notion\`;

    const notifications = [];
    
    // Send based on severity
    if (severity === 'Critical' || severity === 'High') {
      // Slack for urgent alerts
      try {
        await $.slack.send({
          channel: '#cloud-alerts',
          text: message
        });
        notifications.push({ channel: 'slack', sent: true });
      } catch (e) {
        notifications.push({ channel: 'slack', sent: false, error: e.message });
      }
      
      // Email for critical only
      if (severity === 'Critical') {
        try {
          await $.email.send({
            to: 'ops-team@company.com',
            subject: \`\${emoji} CRITICAL: Cloud Operations Alert\`,
            html: message.replace(/\\n/g, '<br>')
          });
          notifications.push({ channel: 'email', sent: true });
        } catch (e) {
          notifications.push({ channel: 'email', sent: false, error: e.message });
        }
      }
    }
    
    // Discord for all alerts
    try {
      await $.discord.send({
        webhook_url: process.env.DISCORD_WEBHOOK,
        content: message
      });
      notifications.push({ channel: 'discord', sent: true });
    } catch (e) {
      notifications.push({ channel: 'discord', sent: false, error: e.message });
    }
    
    return {
      notifications_sent: notifications.filter(n => n.sent).length,
      channels: notifications
    };
  }
})`
    },
    
