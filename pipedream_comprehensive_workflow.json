      "id": "input_router",
      "name": "Route Input by Source",
      "type": "code",
      "code": `
export default defineComponent({
  async run({ steps, $ }) {
    // Determine input source and route accordingly
    const trigger = steps.trigger;
    
    let inputType, data;
    
    if (trigger.event?.headers?.['x-webhook-source']) {
      inputType = 'webhook';
      data = trigger.event.body;
    } else if (trigger.event?.schedule) {
      inputType = 'scheduled';
      data = { task: 'optimization_scan' };
    } else if (trigger.event?.email) {
      inputType = 'email';
      data = { 
        subject: trigger.event.subject,
        body: trigger.event.body,
        from: trigger.event.from
      };
    } else if (trigger.event?.s3) {
      inputType = 's3_event';
      data = trigger.event.detail;
    } else {
      inputType = 'unknown';
      data = trigger.event;
    }
    
    $.flow.inputType = inputType;
    $.flow.timestamp = new Date().toISOString();
    
    return {
      inputType,
      data,
      timestamp: $.flow.timestamp,
      correlationId: $.meta.id
    };
  }
})`
    },
    
    {
      "id": "enrich_context",
      "name": "Enrich with Multi-Cloud Context",
      "type": "code",
      "code": `
export default defineComponent({
  async run({ steps, $ }) {
    const { inputType, data } = steps.input_router.$return_value;
    
    // Call AWS Unified MCP for comprehensive context
    const enrichmentPromises = [];
    
    // Get edge device status
    enrichmentPromises.push(
      fetch('http://localhost:3002/query', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          service: 'edge',
          query: 'device status'
        })
      }).then(r => r.text()).catch(e => ({ error: e.message }))
    );
    
    // Get AWS resource info if resource_id provided
    if (data.resource_id) {
      enrichmentPromises.push(
        fetch('http://localhost:3002/query', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            service: 'knowledge',
            query: \`resource details \${data.resource_id}\`
          })
        }).then(r => r.json()).catch(e => ({ error: e.message }))
      );
    }
    
    // Get cost analysis
    enrichmentPromises.push(
      fetch('http://localhost:3002/query', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          service: 'edge',
          query: 'cost analysis'
        })
      }).then(r => r.text()).catch(e => ({ error: e.message }))
    );
    
    const [edgeStatus, resourceInfo, costAnalysis] = await Promise.all(enrichmentPromises);
    
    return {
      original: data,
      inputType,
      enrichment: {
        edgeStatus,
        resourceInfo,
        costAnalysis,
        enrichedAt: new Date().toISOString()
      }
    };
  }
})`
