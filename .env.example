# Cloud-Ops Platform Environment Variables Example
# Copy to .env and fill in your actual values

# API Configuration
API_HOST=0.0.0.0
API_PORT=5001

# Oracle Database
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=FREE
ORACLE_USER=ANALYTICS
ORACLE_PASSWORD=your_password_here

# Oracle ADB Wallet (if using Autonomous Database)
ORACLE_WALLET_LOCATION=/path/to/wallet
ORACLE_WALLET_PASSWORD=wallet_password_here

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here

# AWS Unified MCP Server
AWS_UNIFIED_URL=http://localhost:3002
AWS_UNIFIED_TIMEOUT=30

# MCP Server HTTP Mode (optional - for cloud deployment)
# MCP_HTTP_PORT=3002
# PORT=3002

# Security Configuration
JWT_SECRET=your_jwt_secret_here_64_characters_minimum_for_production_use
PIPEDREAM_API_KEY=your_pipedream_api_key_here
MONITORING_API_KEY=your_monitoring_api_key_here  
ADMIN_API_KEY=your_admin_api_key_here
RATE_LIMIT_MAX=100
LOG_DIR=/var/log/mcp-server

# Secrets Management (optional - for production)
SECRETS_PROVIDER=auto  # auto|1password|aws|vault|env
OP_VAULT=Private  # 1Password vault name
VAULT_ADDR=http://localhost:8200  # HashiCorp Vault address
VAULT_PATH=secret  # Vault path prefix
AWS_REGION=us-east-1  # AWS region for Secrets Manager

# Notion Configuration
NOTION_TOKEN=your_notion_token_here
NOTION_RESOURCES_DB_ID=your_resources_db_id
NOTION_PROJECTS_DB_ID=your_projects_db_id
NOTION_INCIDENTS_DB_ID=your_incidents_db_id
NOTION_TASKS_DB_ID=your_tasks_db_id

# Project Configuration
DEFAULT_PROJECT_ID=cloud-ops-prod
MONTHLY_BUDGET=10.0

# Environment
CLOUD_OPS_ENV=development